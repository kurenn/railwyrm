<% content_for :title, "Pipeline" %>

<section class="space-y-6">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-900">Pipeline board</h1>
      <p class="mt-1 text-sm text-slate-500">Move candidates across stages and keep workflow current.</p>
    </div>

    <%= form_with url: pipeline_path, method: :get, class: "flex gap-2" do %>
      <select name="job_posting_id" class="rounded-xl border border-slate-300 px-3 py-2 text-sm">
        <% @job_postings.each do |job| %>
          <option value="<%= job.id %>" <%= "selected" if @job_posting&.id == job.id %>><%= job.title %></option>
        <% end %>
      </select>
      <button class="rounded-xl border border-slate-300 px-3 py-2 text-sm text-slate-700">Load</button>
    <% end %>
  </header>

  <% if @job_posting %>
    <div class="grid gap-4 lg:grid-cols-4">
      <% @pipeline_stages.each do |stage| %>
        <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500"><%= stage.name %></h2>

          <ul class="mt-3 space-y-3">
            <% @applications_by_stage.fetch(stage, []).each do |application| %>
              <li class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                <p class="text-sm font-semibold text-slate-900"><%= application.candidate&.full_name || application.candidate&.email %></p>
                <p class="text-xs text-slate-500"><%= application.status.humanize %></p>
                <%= form_with model: application, class: "mt-2" do |form| %>
                  <%= form.collection_select :pipeline_stage_id, @pipeline_stages, :id, :name, {}, class: "w-full rounded-lg border border-slate-300 px-2 py-1 text-xs" %>
                  <%= form.submit "Move", class: "mt-2 rounded-lg bg-slate-900 px-2 py-1 text-xs font-semibold text-white" %>
                <% end %>
                <%= link_to "Open", application_path(application), class: "mt-2 inline-block text-xs font-medium text-violet-700 hover:text-violet-900" %>
              </li>
            <% end %>
          </ul>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-slate-200 bg-white p-6 text-sm text-slate-500 shadow-sm">No job postings found yet.</div>
  <% end %>
</section>
