<% content_for :title, "New Department" %>

<section class="mx-auto max-w-2xl rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <h1 class="text-2xl font-semibold text-slate-900">Create department</h1>

  <%= form_with model: @department, class: "mt-4 space-y-4" do |form| %>
    <% if @department.errors.any? %>
      <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"><%= @department.errors.full_messages.to_sentence %></div>
    <% end %>
    <div>
      <%= form.label :name, class: "text-sm font-medium text-slate-700" %>
      <%= form.text_field :name, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2" %>
    </div>
    <%= form.submit "Save", class: "rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
  <% end %>
</section>
