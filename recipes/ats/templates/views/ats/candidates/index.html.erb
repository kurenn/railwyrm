<% content_for :title, "Candidates" %>

<section class="space-y-6">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-900">Candidates</h1>
      <p class="mt-1 text-sm text-slate-500">Source and manage candidates across your hiring pipeline.</p>
    </div>
    <%= link_to "Add candidate", new_candidate_path, class: "rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
  </header>

  <%= form_with url: candidates_path, method: :get, class: "rounded-2xl border border-slate-200 bg-white p-4 shadow-sm" do %>
    <div class="flex flex-wrap gap-2">
      <input type="text" name="q" value="<%= @query %>" placeholder="Search by name or email" class="w-full max-w-md rounded-xl border border-slate-300 px-3 py-2 text-sm">
      <button class="rounded-xl border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700">Search</button>
    </div>
  <% end %>

  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Candidate</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Location</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Source</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @candidates.each do |candidate| %>
          <tr>
            <td class="px-4 py-3 text-sm">
              <p class="font-medium text-slate-900"><%= candidate.full_name %></p>
              <p class="text-slate-500"><%= candidate.email %></p>
            </td>
            <td class="px-4 py-3 text-sm text-slate-600"><%= candidate.location.presence || "-" %></td>
            <td class="px-4 py-3 text-sm text-slate-600"><%= candidate.source.presence || "-" %></td>
            <td class="px-4 py-3 text-sm">
              <div class="flex gap-2">
                <%= link_to "View", candidate_path(candidate), class: "text-violet-700 hover:text-violet-900" %>
                <%= link_to "Edit", edit_candidate_path(candidate), class: "text-slate-600 hover:text-slate-900" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
