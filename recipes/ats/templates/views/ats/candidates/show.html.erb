<% content_for :title, @candidate.full_name %>

<section class="space-y-6">
  <header class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="text-3xl font-semibold text-slate-900"><%= @candidate.full_name %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= @candidate.email %> • <%= @candidate.location.presence || "Location not set" %></p>
    <div class="mt-4 flex flex-wrap gap-2">
      <%= link_to "Edit profile", edit_candidate_path(@candidate), class: "rounded-xl border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700" %>
      <%= link_to "View pipeline", pipeline_path, class: "rounded-xl border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700" %>
    </div>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Create application</h2>
      <%= form_with url: applications_path, scope: :application, method: :post, class: "mt-4 space-y-3" do |form| %>
        <div>
          <label class="text-sm font-medium text-slate-700">Job</label>
          <%= form.select :job_posting_id, @job_options.map { |job| [job.title, job.id] }, {}, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        </div>
        <%= form.hidden_field :candidate_id, value: @candidate.id %>
        <%= form.submit "Create application", class: "rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
      <% end %>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Profile details</h2>
      <dl class="mt-3 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-slate-500">Source</dt><dd class="text-slate-900"><%= @candidate.source.presence || "-" %></dd></div>
        <div class="flex justify-between gap-4"><dt class="text-slate-500">Phone</dt><dd class="text-slate-900"><%= @candidate.phone.presence || "-" %></dd></div>
        <div class="flex justify-between gap-4"><dt class="text-slate-500">LinkedIn</dt><dd class="text-slate-900"><%= @candidate.linkedin_url.presence || "-" %></dd></div>
      </dl>
    </article>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Applications</h2>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Job</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Stage</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <% @applications.each do |application| %>
            <tr>
              <td class="px-4 py-3 text-sm text-slate-900"><%= application.job_posting&.title %></td>
              <td class="px-4 py-3 text-sm text-slate-600"><%= application.pipeline_stage&.name %></td>
              <td class="px-4 py-3 text-sm text-slate-600"><%= application.status.humanize %></td>
              <td class="px-4 py-3 text-sm"><%= link_to "Open", application_path(application), class: "text-violet-700 hover:text-violet-900" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>
