<% content_for :title, "Reports" %>

<section class="space-y-6">
  <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-900">Reports</h1>
      <p class="mt-1 text-sm text-slate-500">Review funnel conversion, hiring outcomes, and department performance.</p>
    </div>
    <%= link_to "Export CSV", reports_path(format: :csv), class: "rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700" %>
  </header>

  <section class="grid gap-4 md:grid-cols-3">
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <p class="text-sm text-slate-500">Applications</p>
      <p class="mt-2 text-3xl font-semibold text-slate-900"><%= @applications_by_status.values.sum %></p>
    </article>
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <p class="text-sm text-slate-500">Offers</p>
      <p class="mt-2 text-3xl font-semibold text-slate-900"><%= @offers_by_status.values.sum %></p>
    </article>
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <p class="text-sm text-slate-500">Departments</p>
      <p class="mt-2 text-3xl font-semibold text-slate-900"><%= @applications_by_department.size %></p>
    </article>
  </section>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Applications by status</h2>
      <ul class="mt-4 space-y-2">
        <% @applications_by_status.each do |status, total| %>
          <li class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2 text-sm">
            <span class="text-slate-600"><%= status.humanize %></span>
            <span class="font-semibold text-slate-900"><%= total %></span>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Applications by department</h2>
      <ul class="mt-4 space-y-2">
        <% @applications_by_department.each do |department, total| %>
          <li class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2 text-sm">
            <span class="text-slate-600"><%= department %></span>
            <span class="font-semibold text-slate-900"><%= total %></span>
          </li>
        <% end %>
      </ul>
    </article>
  </section>
</section>
