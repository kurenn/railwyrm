<% content_for :title, "Application" %>

<section class="space-y-6">
  <header class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="text-3xl font-semibold text-slate-900"><%= @application.candidate&.full_name || @application.candidate&.email %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= @application.job_posting&.title %> • Applied <%= @application.applied_at&.to_date || "-" %></p>

    <%= form_with model: @application, class: "mt-4 grid gap-3 md:grid-cols-3" do |form| %>
      <div>
        <%= form.label :status, class: "text-sm font-medium text-slate-700" %>
        <%= form.select :status, Application.statuses.keys.map { |status| [status.humanize, status] }, {}, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= form.label :pipeline_stage_id, "Pipeline stage", class: "text-sm font-medium text-slate-700" %>
        <%= form.collection_select :pipeline_stage_id, @available_stages, :id, :name, {}, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div class="flex items-end">
        <%= form.submit "Update application", class: "w-full rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
      </div>
    <% end %>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Schedule interview</h2>
      <%= form_with model: [@application, Interview.new], class: "mt-4 space-y-3" do |form| %>
        <div class="grid gap-3 md:grid-cols-2">
          <div>
            <%= form.label :kind, class: "text-sm font-medium text-slate-700" %>
            <%= form.select :kind, Interview.kinds.keys.map { |kind| [kind.humanize, kind] }, {}, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
          </div>
          <div>
            <%= form.label :location, class: "text-sm font-medium text-slate-700" %>
            <%= form.text_field :location, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm", placeholder: "Video" %>
          </div>
          <div>
            <%= form.label :starts_at, class: "text-sm font-medium text-slate-700" %>
            <%= form.datetime_local_field :starts_at, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
          </div>
          <div>
            <%= form.label :ends_at, class: "text-sm font-medium text-slate-700" %>
            <%= form.datetime_local_field :ends_at, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
          </div>
        </div>
        <%= form.text_field :meeting_url, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-sm", placeholder: "https://meet.example.com/room" %>
        <%= form.submit "Add interview", class: "rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
      <% end %>

      <ul class="mt-4 space-y-2 text-sm text-slate-600">
        <% @interviews.each do |interview| %>
          <li class="rounded-lg border border-slate-200 px-3 py-2">
            <p class="font-medium text-slate-900"><%= interview.kind.humanize %> • <%= l(interview.starts_at, format: :short) if interview.starts_at %></p>
            <p><%= interview.location %></p>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Add feedback</h2>
      <%= form_with model: [@application, Feedback.new], class: "mt-4 space-y-3" do |form| %>
        <div>
          <%= form.label :interview_id, "Interview", class: "text-sm font-medium text-slate-700" %>
          <%= form.collection_select :interview_id, @interviews, :id, :kind, { prompt: "Select interview" }, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= form.label :score, class: "text-sm font-medium text-slate-700" %>
          <%= form.number_field :score, min: 1, max: 5, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        </div>
        <%= form.text_area :summary, rows: 3, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-sm", placeholder: "Summary" %>
        <%= form.submit "Submit feedback", class: "rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
      <% end %>

      <div class="mt-4 space-y-2 text-sm text-slate-600">
        <% @feedbacks.each do |feedback| %>
          <article class="rounded-lg border border-slate-200 px-3 py-2">
            <p class="font-medium text-slate-900">Score: <%= feedback.score || "-" %></p>
            <p><%= feedback.summary.presence || "No summary" %></p>
          </article>
        <% end %>
      </div>
    </article>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Offer management</h2>

    <%= form_with model: [@application, Offer.new], class: "mt-4 grid gap-3 md:grid-cols-4" do |form| %>
      <%= form.number_field :salary, placeholder: "Salary", class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
      <%= form.text_field :equity, placeholder: "Equity", class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
      <%= form.date_field :starts_on, class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
      <%= form.select :status, Offer::STATUSES, { prompt: "Status" }, class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
      <div class="md:col-span-4">
        <%= form.submit "Create offer", class: "rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
      </div>
    <% end %>

    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Salary</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Equity</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <% @offers.each do |offer| %>
            <tr>
              <td class="px-4 py-3 text-sm text-slate-900"><%= number_to_currency(offer.salary || 0) %></td>
              <td class="px-4 py-3 text-sm text-slate-600"><%= offer.equity.presence || "-" %></td>
              <td class="px-4 py-3 text-sm text-slate-600"><%= offer.status.presence || "draft" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>
