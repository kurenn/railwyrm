<section class="mx-auto w-full max-w-6xl space-y-8 px-4 py-10 sm:px-6 lg:px-8">
  <header class="space-y-2">
    <p class="text-sm font-medium text-violet-600">Careers</p>
    <h1 class="text-4xl font-semibold text-slate-900">Join our team</h1>
    <p class="text-sm text-slate-500">Open opportunities across product, engineering, and operations.</p>
  </header>

  <div class="space-y-4">
    <% @job_postings.each do |job| %>
      <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900"><%= link_to job.title, career_path(job), class: "hover:text-violet-700" %></h2>
        <p class="mt-1 text-sm text-slate-500"><%= job.department&.name %> • <%= job.location.presence || "Remote" %> • <%= job.employment_type %></p>
      </article>
    <% end %>
  </div>
</section>
