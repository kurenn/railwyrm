<section class="mx-auto w-full max-w-4xl space-y-6 px-4 py-10 sm:px-6 lg:px-8">
  <header class="space-y-2">
    <p class="text-sm font-medium text-violet-600">Career opportunity</p>
    <h1 class="text-3xl font-semibold text-slate-900"><%= @job_posting.title %></h1>
    <p class="text-sm text-slate-500"><%= @job_posting.location.presence || "Remote" %> • <%= @job_posting.employment_type %> • <%= @job_posting.department&.name %></p>
  </header>

  <article class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Role description</h2>
    <p class="mt-3 whitespace-pre-wrap text-sm leading-6 text-slate-600"><%= @job_posting.description.presence || "We're looking for an exceptional teammate." %></p>

    <h3 class="mt-5 text-sm font-semibold uppercase tracking-wide text-slate-500">Requirements</h3>
    <p class="mt-2 whitespace-pre-wrap text-sm leading-6 text-slate-600"><%= @job_posting.requirements.presence || "Strong collaboration and execution skills." %></p>
  </article>

  <article class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Apply now</h2>
    <%= form_with url: career_applications_path(@job_posting), scope: :candidate, class: "mt-4 space-y-4" do |form| %>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <%= form.label :first_name, class: "text-sm font-medium text-slate-700" %>
          <%= form.text_field :first_name, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2" %>
        </div>
        <div>
          <%= form.label :last_name, class: "text-sm font-medium text-slate-700" %>
          <%= form.text_field :last_name, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2" %>
        </div>
        <div>
          <%= form.label :email, class: "text-sm font-medium text-slate-700" %>
          <%= form.email_field :email, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2" %>
        </div>
        <div>
          <%= form.label :phone, class: "text-sm font-medium text-slate-700" %>
          <%= form.text_field :phone, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2" %>
        </div>
      </div>

      <%= form.text_field :location, placeholder: "Location", class: "w-full rounded-xl border border-slate-300 px-3 py-2" %>
      <%= form.url_field :linkedin_url, placeholder: "LinkedIn URL", class: "w-full rounded-xl border border-slate-300 px-3 py-2" %>
      <%= form.url_field :portfolio_url, placeholder: "Portfolio URL", class: "w-full rounded-xl border border-slate-300 px-3 py-2" %>
      <%= form.text_area :notes, rows: 4, placeholder: "Tell us why you're a fit", class: "w-full rounded-xl border border-slate-300 px-3 py-2" %>

      <%= form.submit "Submit application", class: "rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
    <% end %>
  </article>
</section>
