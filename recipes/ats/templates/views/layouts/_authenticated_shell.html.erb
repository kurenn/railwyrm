<% display_name = if current_user.respond_to?(:name) && current_user.name.present?
                    current_user.name
                  else
                    current_user.email.to_s.split("@").first.to_s.tr("._", " ").split.map(&:capitalize).join(" ")
                  end %>

<div class="min-h-screen bg-[#f8f9fc] text-slate-900">
  <div class="flex min-h-screen">
    <aside class="hidden w-72 shrink-0 border-r border-slate-200 bg-white px-5 py-6 lg:flex lg:flex-col">
      <div class="flex items-center gap-3">
        <div class="h-8 w-8 rounded-xl bg-gradient-to-br from-violet-500 to-indigo-500"></div>
        <p class="text-xl font-semibold text-slate-900">Untitled UI</p>
      </div>

      <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5">
        <div class="flex items-center justify-between gap-3 text-sm text-slate-500">
          <span>Search</span>
          <kbd class="rounded-md border border-slate-300 bg-white px-1.5 py-0.5 text-xs text-slate-400">⌘K</kbd>
        </div>
      </div>

      <% nav_links = [
        ["Home", authenticated_root_path],
        ["Dashboard", authenticated_root_path],
        ["Projects", job_postings_path],
        ["Tasks", pipeline_path],
        ["Reporting", reports_path],
        ["Users", candidates_path]
      ] %>

      <nav class="mt-6 space-y-1.5">
        <% nav_links.each do |label, path| %>
          <% active = current_page?(path) %>
          <%= link_to path, class: "flex items-center rounded-lg px-3 py-2 text-sm font-medium transition #{active ? 'bg-violet-50 text-violet-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" do %>
            <span><%= label %></span>
          <% end %>
        <% end %>
      </nav>

      <div class="mt-auto rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <p class="text-sm font-semibold text-slate-900">Join our workshop</p>
        <p class="mt-1 text-sm text-slate-500">Learn how to leverage AI to supercharge your workflow.</p>
      </div>
    </aside>

    <div class="min-w-0 flex-1">
      <header class="border-b border-slate-200 bg-white px-4 py-3 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-2 text-sm text-slate-500">
            <span class="font-medium text-slate-700"><%= display_name %></span>
            <span>›</span>
            <span class="font-semibold text-slate-900">Dashboard</span>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 rounded-full bg-gradient-to-br from-slate-300 to-slate-500"></div>
              <div>
                <p class="text-sm font-semibold text-slate-900"><%= display_name %></p>
                <p class="text-sm text-slate-500"><%= current_user.email %></p>
              </div>
            </div>
          </div>
        </div>
      </header>

      <main class="px-4 py-6 sm:px-6 lg:px-8">
        <%= yield %>
      </main>
    </div>
  </div>
</div>
