<%= form_with model: member, class: "space-y-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" do |form| %>
  <% if member.errors.any? %>
    <div class="rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700">
      <%= member.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= form.label :first_name, class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.text_field :first_name, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= form.label :last_name, class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.text_field :last_name, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= form.label :email, class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.email_field :email, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= form.label :phone, class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.text_field :phone, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= form.label :status, class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.select :status, Member.statuses.keys.map { |value| [value.humanize, value] }, {}, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= form.label :joined_on, class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.date_field :joined_on, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= form.label :emergency_contact_name, class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.text_field :emergency_contact_name, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= form.label :emergency_contact_phone, class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.text_field :emergency_contact_phone, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit member.persisted? ? "Save member" : "Create member", class: "rounded-lg bg-violet-600 px-4 py-2 text-sm font-medium text-white" %>
    <%= link_to "Cancel", members_path, class: "text-sm font-medium text-slate-600" %>
  </div>
<% end %>
