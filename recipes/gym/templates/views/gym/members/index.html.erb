<% content_for :title, "Members" %>

<section class="space-y-6">
  <header class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-900">Members</h1>
      <p class="mt-1 text-slate-500">Manage gym members and profile status.</p>
    </div>
    <%= link_to "New member", new_member_path, class: "rounded-lg bg-violet-600 px-4 py-2 text-sm font-medium text-white" %>
  </header>

  <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Name</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Email</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% (defined?(Member) ? Member.order(created_at: :desc).limit(20) : []).each do |member| %>
          <tr>
            <td class="px-4 py-3 text-sm text-slate-900"><%= [member.first_name, member.last_name].compact.join(" ") %></td>
            <td class="px-4 py-3 text-sm text-slate-600"><%= member.email %></td>
            <td class="px-4 py-3 text-right text-sm">
              <%= link_to "View", member_path(member), class: "font-medium text-violet-700" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
