<% content_for :title, "Member" %>

<section class="space-y-6">
  <header class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-900"><%= @member.full_name %></h1>
      <p class="mt-1 text-slate-500"><%= @member.email %> · <%= @member.status.humanize %></p>
    </div>
    <%= link_to "Edit", edit_member_path(@member), class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700" %>
  </header>

  <section class="grid gap-6 xl:grid-cols-2">
    <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-xl font-semibold text-slate-900">Memberships</h2>
      <ul class="mt-4 space-y-3">
        <% @memberships.each do |membership| %>
          <li class="rounded-xl border border-slate-100 px-4 py-3 text-sm text-slate-700">
            <%= membership.membership_plan&.name %> · <%= membership.status.humanize %>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-semibold text-slate-900">Recent visits</h2>
        <%= button_to "Record visit", visits_path(member_id: @member.id), method: :post, class: "rounded-lg bg-violet-600 px-3 py-2 text-sm font-medium text-white" %>
      </div>
      <ul class="mt-4 space-y-3">
        <% @recent_visits.each do |visit| %>
          <li class="rounded-xl border border-slate-100 px-4 py-3 text-sm text-slate-700">
            <%= visit.checked_in_at&.strftime("%b %d, %H:%M") %> · <%= visit.source.presence || "front_desk" %>
          </li>
        <% end %>
      </ul>
    </article>
  </section>
</section>
