<% content_for :title, "Member" %>

<section class="space-y-6">
  <header class="flex items-center justify-between">
    <h1 class="text-3xl font-semibold text-slate-900">Member profile</h1>
    <%= link_to "Edit", edit_member_path(params[:id]), class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700" %>
  </header>

  <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <p class="text-slate-600">This starter page is ready for detailed member profile content.</p>
  </article>
</section>
