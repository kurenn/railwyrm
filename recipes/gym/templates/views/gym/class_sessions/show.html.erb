<% content_for :title, "Class Session" %>

<section class="space-y-6">
  <header class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-900"><%= @class_session.title %></h1>
      <p class="mt-1 text-slate-500">
        <%= @class_session.starts_at.strftime("%b %d, %H:%M") %> · <%= @class_session.instructor_name %> · <%= @class_session.status.humanize %>
      </p>
    </div>
    <%= link_to "Edit", edit_class_session_path(@class_session), class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700" %>
  </header>

  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-slate-900">Book member</h2>
    <%= form_with url: class_session_class_bookings_path(@class_session), method: :post, class: "mt-4 flex flex-col gap-3 sm:flex-row" do |form| %>
      <%= form.select :member_id, @bookable_members.map { |member| [member.full_name, member.id] }, { include_blank: "Select member" }, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
      <%= form.submit "Book", class: "rounded-lg bg-violet-600 px-4 py-2 text-sm font-medium text-white" %>
    <% end %>
  </section>

  <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Member</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Status</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Booked at</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 bg-white">
        <% @bookings.each do |booking| %>
          <tr>
            <td class="px-4 py-3 text-sm text-slate-900"><%= booking.member&.full_name %></td>
            <td class="px-4 py-3 text-sm text-slate-600"><%= booking.status.humanize %></td>
            <td class="px-4 py-3 text-sm text-slate-600"><%= booking.booked_at&.strftime("%b %d, %H:%M") %></td>
            <td class="px-4 py-3 text-right text-sm">
              <div class="inline-flex gap-2">
                <%= button_to "Attend", class_session_class_booking_path(@class_session, booking, status: :attended), method: :patch, class: "rounded border border-slate-300 px-2 py-1 text-xs font-medium text-slate-700" %>
                <%= button_to "Cancel", class_session_class_booking_path(@class_session, booking, status: :canceled), method: :patch, class: "rounded border border-slate-300 px-2 py-1 text-xs font-medium text-slate-700" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
