<% content_for :title, "Membership Plans" %>

<section class="space-y-6">
  <header class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-900">Membership plans</h1>
      <p class="mt-1 text-slate-500">Plan pricing and billing cadence.</p>
    </div>
    <%= link_to "New plan", new_membership_plan_path, class: "rounded-lg bg-violet-600 px-4 py-2 text-sm font-medium text-white" %>
  </header>

  <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Name</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Price</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Billing</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Active</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 bg-white">
        <% @membership_plans.each do |plan| %>
          <tr>
            <td class="px-4 py-3 text-sm text-slate-900"><%= plan.name %></td>
            <td class="px-4 py-3 text-sm text-slate-600"><%= number_to_currency(plan.price_cents.to_i / 100.0) %></td>
            <td class="px-4 py-3 text-sm text-slate-600"><%= plan.billing_cycle.humanize %></td>
            <td class="px-4 py-3 text-sm text-slate-600"><%= plan.active ? "Yes" : "No" %></td>
            <td class="px-4 py-3 text-right text-sm"><%= link_to "Edit", edit_membership_plan_path(plan), class: "font-medium text-violet-700" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
