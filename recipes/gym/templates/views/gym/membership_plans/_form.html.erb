<%= form_with model: membership_plan, class: "space-y-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" do |form| %>
  <% if membership_plan.errors.any? %>
    <div class="rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700"><%= membership_plan.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= form.label :name, class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.text_field :name, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= form.label :price_cents, "Price (cents)", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.number_field :price_cents, min: 0, step: 100, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= form.label :billing_cycle, class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.select :billing_cycle, [["Monthly", "monthly"], ["Quarterly", "quarterly"], ["Yearly", "yearly"]], {}, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div class="flex items-center gap-2 pt-7">
      <%= form.check_box :active, class: "rounded border-slate-300" %>
      <%= form.label :active, class: "text-sm font-medium text-slate-700" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit membership_plan.persisted? ? "Save plan" : "Create plan", class: "rounded-lg bg-violet-600 px-4 py-2 text-sm font-medium text-white" %>
    <%= link_to "Cancel", membership_plans_path, class: "text-sm font-medium text-slate-600" %>
  </div>
<% end %>
