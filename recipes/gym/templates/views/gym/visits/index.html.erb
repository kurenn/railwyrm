<% content_for :title, "Visits" %>

<section class="space-y-6">
  <header>
    <h1 class="text-3xl font-semibold text-slate-900">Visits</h1>
    <p class="mt-1 text-slate-500">Track check-ins and attendance history.</p>
  </header>

  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-slate-900">Quick check-in</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      <% @members.each do |member| %>
        <%= button_to "Check in #{member.full_name}", visits_path(member_id: member.id), method: :post, class: "rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700" %>
      <% end %>
    </div>
  </section>

  <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Member</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Checked in</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Source</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 bg-white">
        <% @visits.each do |visit| %>
          <tr>
            <td class="px-4 py-3 text-sm text-slate-900"><%= visit.member&.full_name %></td>
            <td class="px-4 py-3 text-sm text-slate-600"><%= visit.checked_in_at.strftime("%b %d, %H:%M") %></td>
            <td class="px-4 py-3 text-sm text-slate-600"><%= visit.source.presence || "front_desk" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
