<% content_for :title, "Join Membership" %>

<section class="mx-auto max-w-3xl space-y-6">
  <header>
    <h1 class="text-3xl font-semibold text-slate-900">Join membership</h1>
    <p class="mt-1 text-slate-500">Leave your details and we will get you started.</p>
  </header>

  <%= form_with url: memberships_path, method: :post, class: "space-y-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" do |form| %>
    <% if @member&.errors&.any? %>
      <div class="rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700"><%= @member.errors.full_messages.to_sentence %></div>
    <% end %>

    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= form.label :first_name, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= form.text_field :first_name, name: "member[first_name]", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= form.label :last_name, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= form.text_field :last_name, name: "member[last_name]", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= form.label :email, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= form.email_field :email, name: "member[email]", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= form.label :phone, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= form.text_field :phone, name: "member[phone]", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
      </div>
    </div>

    <div>
      <%= form.label :membership_plan_id, "Preferred plan", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.select :membership_plan_id, @membership_plans.map { |plan| ["#{plan.name} (#{number_to_currency(plan.price)})", plan.id] }, { include_blank: "Choose a plan" }, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>

    <div class="flex items-center gap-3">
      <%= form.submit "Request membership", class: "rounded-lg bg-violet-600 px-4 py-2 text-sm font-medium text-white" %>
      <%= link_to "View schedule", schedule_path, class: "text-sm font-medium text-slate-600" %>
    </div>
  <% end %>
</section>
